Exercise 2: GROUPING SETS
GROUPING SETS → Multiple GROUP BY results in one query

SELECT
c.Region,
p.Category,
SUM(od.Quantity) AS TotalQuantity
FROM Customers c
JOIN Orders o
ON c.CustomerID=o.CustomerID
JOIN OrderDetails od
ON o.OrderID=od.OrderID
JOIN Products p
ON od.ProductID=p.ProductID
GROUP BY GROUPING SETS
(
(c.Region,p.Category),
(c.Region),
(p.Category)
);

ROLLUP
ROLLUP → Subtotals + Grand Total

SELECT
c.Region,
p.Category,
SUM(od.Quantity) AS TotalQuantity
FROM Customers c
JOIN Orders o
ON c.CustomerID=o.CustomerID
JOIN OrderDetails od
ON o.OrderID=od.OrderID
JOIN Products p
ON od.ProductID=p.ProductID
GROUP BY ROLLUP(c.Region,p.Category);

CUBE
CUBE → All possible subtotal combinations

SELECT
c.Region,
p.Category,
SUM(od.Quantity) AS TotalQuantity
FROM Customers c
JOIN Orders o
ON c.CustomerID=o.CustomerID
JOIN OrderDetails od
ON o.OrderID=od.OrderID
JOIN Products p
ON od.ProductID=p.ProductID
GROUP BY CUBE(c.Region,p.Category);

